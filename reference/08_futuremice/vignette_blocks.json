      "type": "console",
      "r_code": "library(magrittr)\nset.seed(123)\nimp1 <- futuremice(nhanes, n.core = 3)\nset.seed(123)\nimp2 <- futuremice(nhanes, n.core = 3)\nimp1 %$% lm(chl ~ bmi) %>% pool %$% pooled",
