      "index": 0,
      "type": "setup",
      "r_code": "set.seed(123)\n\nsmall_covmat <- diag(4)\nsmall_covmat[small_covmat == 0] <- 0.5\nsmall_data <- MASS::mvrnorm(1000, \n                      mu = c(0, 0, 0, 0),\n                      Sigma = small_covmat)\n\nsmall_data_with_missings <- ampute(small_data, prop = 0.8, mech = \"MCAR\")$amp\nhead(small_data_with_missings)",
      "r_output": "",
      "figure": null
    },
    {
      "index": 1,
      "type": "console",
      "r_code": "imp <- futuremice(nhanes)",
      "r_output": "Number of cores not specified. Based on your machine a value of n.core = 3 is chosen; the imputations are distributed about equally over the cores.",
      "figure": null
    },
    {
      "index": 2,
      "type": "console",
      "r_code": "class(imp)",
      "r_output": "[1] \"mids\"",
      "figure": null
    },
    {
      "index": 3,
      "type": "console",
      "r_code": "imp$call",
      "r_output": "[[1]]\nmice(data = data, m = x, printFlag = F, seed = seed)\n\n[[2]]\nibind(x = imp, y = imps[[i]])\n\n[[3]]\nibind(x = imp, y = imps[[i]])",
      "figure": null
    },
    {
      "index": 4,
      "type": "console",
      "r_code": "imp$parallelseed",
      "r_output": "[1] 198128673",
      "figure": null
    },
    {
      "index": 5,
      "type": "console",
      "r_code": "imp <- futuremice(nhanes, method = \"norm\")",
