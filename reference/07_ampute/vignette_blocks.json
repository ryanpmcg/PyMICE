    {
      "index": 21,
      "type": "plot",
      "r_code": "bwplot(result, which.pat = 1, descriptives = TRUE)",
      "r_output": "$Descriptives\n, , Variable =  V1\n\n       Descriptives\nPattern Amp     Mean     Var    N\n      1   1  0.11770 0.96079 3552\n      1   0 -0.12512 0.99905 3495\n\n, , Variable =  V2\n\n       Descriptives\nPattern Amp     Mean     Var    N\n      1   1  0.36608 0.84028 3552\n      1   0 -0.39542 0.85435 3495\n\n, , Variable =  V3\n\n       Descriptives\nPattern Amp     Mean     Var    N\n      1   1  0.22595 0.96457 3552\n      1   0 -0.26021 0.90809 3495\n\n\n$`Boxplot pattern 1`",
      "figure": "fig_010.png"
    },
    {
      "index": 22,
      "type": "console",
      "r_code": "BSDA::tsum.test(mean.x = 0.39077, mean.y = -0.38992, s.x = sqrt(0.83774), s.y = sqrt(0.87721), n.x = 3473, n.y = 3493)",
      "r_output": "Welch Modified Two-Sample t-Test\n\ndata:  Summarized x and y\nt = 35.184, df = 6961.9, p-value < 2.2e-16\nalternative hypothesis: true difference in means is not equal to 0\n95 percent confidence interval:\n 0.7371929 0.8241871\nsample estimates:\nmean of x mean of y\n  0.39077  -0.38992",
      "figure": null
    },
    {
      "index": 23,
      "type": "plot",
      "r_code": "result <- ampute(testdata, freq = myfreq, patterns = mypatterns,\n                 weights = myweights, cont = TRUE,\n                 type = c(\"RIGHT\", \"TAIL\", \"MID\", \"LEFT\"))\nbwplot(result, which.pat = 2, descriptives = FALSE)",
      "r_output": "$`Boxplot pattern 2`",
      "figure": null
