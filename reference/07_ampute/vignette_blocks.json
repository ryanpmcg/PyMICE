  "blocks": [
    {
      "index": 0,
      "type": "setup",
      "r_code": "library(\"mice\")\nhelp(ampute)",
      "r_output": "",
      "figure": null
    },
    {
      "index": 1,
      "type": "console",
      "r_code": "set.seed(2016)\ntestdata <- as.data.frame(MASS::mvrnorm(n = 10000,\n                                        mu = c(10, 5, 0),\n                                        Sigma = matrix(data = c(1.0, 0.2, 0.2,\n                                                                0.2, 1.0, 0.2,\n                                                                0.2, 0.2, 1.0),\n                                                       nrow = 3,\n                                                       byrow = T)))\nsummary(testdata)",
      "r_output": "V1               V2               V3\n Min.   : 6.346   Min.   :0.9789   Min.   :-3.799124\n 1st Qu.: 9.317   1st Qu.:4.3199   1st Qu.:-0.690542\n Median :10.003   Median :4.9963   Median :-0.009941\n Mean   : 9.998   Mean   :4.9973   Mean   : 0.000759\n 3rd Qu.:10.677   3rd Qu.:5.6759   3rd Qu.: 0.673069\n Max.   :13.770   Max.   :8.6579   Max.   : 3.810729",
      "figure": null
    },
    {
      "index": 2,
      "type": "console",
      "r_code": "result <- ampute(data = testdata)\nclass(result)",
      "r_output": "[1] \"mads\"",
      "figure": null
