    {
      "index": 1,
      "type": "console",
      "r_code": "ini <- mice(mammalsleep[, -1], maxit=0, print=F)\nmeth<- ini$meth\nmeth",
      "r_output": "bw   brw   sws    ps    ts   mls    gt    pi   sei   odi\n   \"\"    \"\" \"pmm\" \"pmm\" \"pmm\" \"pmm\" \"pmm\"    \"\"    \"\"    \"\"",
      "figure": null
